{% extends 'base.html.twig' %}

{% block title %}Theme index{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-6 text-gray-800">Liste des Thèmes</h1>

<div class="shadow-md rounded-lg overflow-hidden">
    <table class="min-w-full leading-normal">
        <thead class="bg-gray-200 text-gray-600 uppercase text-sm">
            <tr>
                <th class="px-5 py-3 border-b-2 border-gray-200 text-left">Id</th>
                <th class="px-5 py-3 border-b-2 border-gray-200 text-left">Nom</th>
                <th class="px-5 py-3 border-b-2 border-gray-200 text-left">actions</th>
            </tr>
        </thead>
        <tbody>
        {% for theme in themes %}
            <tr class="bg-white hover:bg-gray-100 border-b border-gray-200">
                <td class="px-5 py-5 text-sm">{{ theme.id }}</td>
                <td class="px-5 py-5 text-sm">{{ theme.nom }}</td>
                <td class="px-5 py-5 text-sm">
                    <a href="{{ path('app_theme_show', {'id': theme.id}) }}" class="text-blue-600 hover:text-blue-800 hover:underline">Voir</a>
                    <a href="{{ path('app_theme_edit', {'id': theme.id}) }}" class="text-blue-600 hover:text-blue-800 hover:underline" >Modifier</a>
                </td>
            </tr>
        {% else %}
            <tr class="bg-white hover:bg-gray-100 border-b border-gray-200">
                <td colspan="3" class="px-5 py-5 text-sm">Aucune thème trouvé.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    </div>

    <a href="{{ path('app_theme_new') }}" class="inline-block mt-6 bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded">Create new</a>
</div>
{% endblock %}
