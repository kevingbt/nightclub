{% extends 'base.html.twig' %}
{% form_theme monForm 'tailwind_2_layout.html.twig' %}

{% block title %}Hello GlobalController!
{% endblock %}


{% block body %}
	<style>
		.example-wrapper {
			margin: 1em auto;
			max-width: 800px;
			width: 95%;
			font: 18px / 1.5 sans-serif;
		}
		.example-wrapper code {
			background: #F5F5F5;
			padding: 2px 6px;
		}
	</style>

	<div class="example-wrapper">
		<h1>Ceci est une page de contact
		</h1>

		{{ form_start(monForm, {'attr': {'class': 'space-y-4'}}) }}
		{{ form_widget(monForm)}}
		<button type="submit" class="px-4 py-2 bg-blue-500 text-white rounded">Envoyer</button>
		{{ form_end(monForm) }}
		{{ ux_map(map, {style: 'height: 600px;'}) }}
	</div>
{% endblock %}
