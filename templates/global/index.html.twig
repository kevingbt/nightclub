{% extends 'base.html.twig' %}

{% block title %}Hello GlobalController!
{% endblock %}

{% block body %}
	<style>
		.example-wrapper {
			margin: 1em auto;
			max-width: 800px;
			width: 95%;
			font: 18px / 1.5 sans-serif;
		}
		.example-wrapper code {
			background: #F5F5F5;
			padding: 2px 6px;
		}
	</style>

	<div class="example-wrapper">
		<h1 class="text-3xl font-bold mb-4 text-steal-900;">
			{{ title }}</h1>
		<div class="mb-4">
			<img src="{{ asset('image/boule.jpg') }}" style="width: 600px; height: auto;" alt="Image de test">
		</div>
		<div class="mb-4">
			<h2 class="text-2xl font-bold mb-2 text-steal-900;">Prochaines soirées</h2>
			<ul class="list-disc pl-5">
				{% for soiree in soirees %}
					<li class="mb-2">
						<strong>{{ soiree.titre }}</strong>
						-
						{{ soiree.dateSoiree|date('d/m/Y') }}
					</li>
				{% else %}
					<li>Aucune soirée à venir.</li>
				{% endfor %}
			</ul>
		</div>
	{% endblock %}
