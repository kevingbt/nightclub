{% extends 'base.html.twig' %}

{% block title %}Hello GlobalController!
{% endblock %}

{% block body %}
	<style>
		.example-wrapper {
			margin: 1em auto;
			max-width: 800px;
			width: 95%;
			font: 18px / 1.5 sans-serif;
		}
		.example-wrapper code {
			background: #F5F5F5;
			padding: 2px 6px;
		}
	</style>

	<div class="example-wrapper">
		<h1>À propos</h1>
		<h2>Notre histoire</h2>
		<ul>
			{% for historique in historiques %}
				<li>{{historique.année}}
					:
					{{historique.texte}}</li>
            {% else %}
                <li>Aucune information historique disponible.</li>
			{% endfor %}
		</ul>
	</div>
{% endblock %}
